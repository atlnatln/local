@pytest_asyncio.fixture
async def telegram_app():
    """Build TelegramBot Application with mocked Bot API.

    Yields a tuple (TelegramBot, Application).  The Application is
    initialized on entry and shut down on exit.  All Bot network calls
    are mocked so no real Telegram traffic is sent.
    """
    from unittest.mock import patch
    from bot.config import Config
    from bot.telegram import TelegramBot

    with patch.object(Config, "TELEGRAM_TOKEN", TEST_TELEGRAM_TOKEN):
        tb = TelegramBot()
        app = tb.build()

    # Mock every network method we might hit.
    # ExtBot is frozen by default — we temporarily disable freezing.
    app.bot._frozen = False
    app.bot.send_message = AsyncMock(return_value=MagicMock(message_id=1))
    app.bot.delete_message = AsyncMock(return_value=True)
    app.bot.edit_message_text = AsyncMock(return_value=MagicMock(message_id=1))
    app.bot._frozen = True

    # Skip real network initialization (getMe call) — we never talk to Telegram servers
    from telegram import User

    # Temporarily unfreeze so we can inject the cached bot user
    app.bot._frozen = False
    app.bot._bot_user = User(id=1, is_bot=True, first_name="TestBot", username="test_bot")
    app.bot._initialized = True
    app.bot._frozen = True

    app.initialize = AsyncMock()
    app.shutdown = AsyncMock()
    app._initialized = True
    yield tb, app


def _make_update(payload: dict, bot) -> "Update":
    """Helper: build a python-telegram-bot Update from a JSON-like dict."""
    from telegram import Update

    return Update.de_json(payload, bot)


