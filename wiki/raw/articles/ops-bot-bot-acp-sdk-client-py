"""Ops-bot ACP Client implementation for the official SDK."""
from __future__ import annotations

import logging
import re
import subprocess
from typing import Any

import acp
import acp.schema as schema
from acp.contrib import SessionAccumulator, ToolCallTracker

logger = logging.getLogger(__name__)

RISKY_COMMANDS = {
    "git", "rm", "mv", "cp", "chmod", "chown", "sudo",
    "mkfs", "dd", "wget", "curl", "nc", "netcat", "nmap",
}


class OpsBotAcpClient:
    """Minimal ACP client implementing the Protocol for ops-bot."""

    def __init__(self) -> None:
        self.accumulator = SessionAccumulator()
        self.tool_tracker = ToolCallTracker()
        self.tool_call_count = 0
        self.context_used = 0
        self.context_size = 0
        self._terminals: dict[str, str] = {}

    async def session_update(
        self,
        session_id: str,
        update: Any,
        **kwargs: Any,
    ) -> None:
        """Accumulate session updates and track tool calls / context usage."""
        notification = acp.SessionNotification(session_id=session_id, update=update)
        self.accumulator.apply(notification)

        # Track tool calls
        if hasattr(update, "tool_call") and update.tool_call:
            self.tool_call_count += 1
            logger.info("Tool call count=%s", self.tool_call_count)

        # Track context usage if available
        if hasattr(update, "type") and getattr(update, "type", None) == "usage_update":
            self.context_used = getattr(update, "used", 0)
            self.context_size = getattr(update, "size", 0)
            logger.info("Context usage updated: %s / %s", self.context_used, self.context_size)

    async def request_permission(
        self,
        options: list[Any],
        session_id: str,
        tool_call: Any,
        **kwargs: Any,
    ) -> acp.RequestPermissionResponse:
        """Auto-approve/reject with word-boundary risky command filter."""
        description = ""
        if tool_call and hasattr(tool_call, "title"):
            description = str(tool_call.title) or ""
        elif tool_call and hasattr(tool_call, "content"):
            description = str(tool_call.content) or ""

        tool_words = set(re.findall(r"\b\w+\b", description.lower()))
        is_risky = not RISKY_COMMANDS.isdisjoint(tool_words)

        if is_risky:
            logger.warning("REJECT risky: %s", description[:200])
            return acp.RequestPermissionResponse(
                outcome=schema.DeniedOutcome(outcome="cancelled")
            )
        logger.info("APPROVE: %s", description[:200])
        return acp.RequestPermissionResponse(
            outcome=schema.AllowedOutcome(option_id="approve", outcome="selected")
        )

    # Tool implementations — now execute real work instead of stubs
    async def write_text_file(self, content: str, path: str, session_id: str, **kwargs: Any) -> Any:
        logger.info("write_text_file: %s", path)
        try:
            from bot.config import Config
            real_path = os.path.realpath(path)
            root = os.path.realpath(Config.REPO_ROOT)
            if not real_path.startswith(root + os.sep) and real_path != root:
                logger.warning("Blocked write outside repo: %s", path)
                return None
            basename = os.path.basename(real_path).lower()
            if basename in {".env", ".env.production", ".env.local", "id_rsa", "id_ed25519", "authorized_keys"}:
                logger.warning("Blocked sensitive file write: %s", path)
                return None
            os.makedirs(os.path.dirname(real_path), exist_ok=True)
            with open(real_path, "w", encoding="utf-8") as f:
                f.write(content)
        except Exception as exc:
            logger.warning("write_text_file failed: %s", exc)
        return None

    async def read_text_file(self, path: str, session_id: str, **kwargs: Any) -> Any:
        logger.info("read_text_file: %s", path)
        try:
            from bot.config import Config
            real_path = os.path.realpath(path)
            root = os.path.realpath(Config.REPO_ROOT)
            if not real_path.startswith(root + os.sep) and real_path != root:
                logger.warning("Blocked read outside repo: %s", path)
                return schema.ReadTextFileResponse(content="[Access denied: outside project directory]")
            basename = os.path.basename(real_path).lower()
            if basename in {".env", ".env.production", ".env.local", "id_rsa", "id_ed25519", "authorized_keys"}:
                logger.warning("Blocked sensitive file read: %s", path)
                return schema.ReadTextFileResponse(content="[Access denied: sensitive file]")
            with open(real_path, "r", encoding="utf-8", errors="replace") as f:
                content = f.read()
            return schema.ReadTextFileResponse(content=content)
        except Exception as exc:
            logger.warning("read_text_file failed: %s", exc)
            return schema.ReadTextFileResponse(content=f"[Error reading file: {exc}]")

    async def create_terminal(self, command: str, session_id: str, **kwargs: Any) -> Any:
        logger.info("create_terminal: %s", command)
        try:
            from bot.config import Config
            cmd = command or ""
            result = subprocess.run(
                cmd, shell=True, capture_output=True, text=True, timeout=30, cwd=Config.REPO_ROOT
            )
            output = result.stdout + result.stderr
        except Exception as exc:
            output = f"Error: {exc}"
        tid = f"term-{len(self._terminals)}"
        self._terminals[tid] = output
        return schema.CreateTerminalResponse(terminal_id=tid)

    async def terminal_output(self, session_id: str, terminal_id: str, **kwargs: Any) -> Any:
        output = self._terminals.get(terminal_id, "")
        return schema.TerminalOutputResponse(output=output, truncated=False)

    async def release_terminal(self, session_id: str, terminal_id: str, **kwargs: Any) -> Any:
        self._terminals.pop(terminal_id, None)
        return schema.ReleaseTerminalResponse()

    async def wait_for_terminal_exit(self, session_id: str, terminal_id: str, **kwargs: Any) -> Any:
        return schema.WaitForTerminalExitResponse(exit_code=0)

    async def kill_terminal(self, session_id: str, terminal_id: str, **kwargs: Any) -> Any:
        return None

    async def ext_method(self, method: str, params: dict[str, Any]) -> dict[str, Any]:
        logger.warning("ext_method: %s %s", method, params)
        return {}

    async def ext_notification(self, method: str, params: dict[str, Any]) -> None:
        logger.warning("ext_notification: %s %s", method, params)
