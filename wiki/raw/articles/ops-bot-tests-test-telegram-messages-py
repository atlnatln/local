# ---------------------------------------------------------------------------
# Message length & chunking
# ---------------------------------------------------------------------------

@pytest.mark.asyncio
async def test_long_message_split_into_chunks(telegram_app, mock_update_text, test_user_id):
    """A 9000-char answer + footer must be split correctly (<=4000 each)."""
    tb, app = telegram_app
    tb.executor.run = AsyncMock(return_value="A" * 9000)

    update = mock_update_text("uzun rapor", user_id=test_user_id)
    await app.process_update(update)

    calls = app.bot.send_message.call_args_list
    # ACK + chunks + optional footer = at least 4 calls
    assert len(calls) >= 4

    # Verify chunk sizes (each chunk <= 4000)
    for call in calls[1:]:
        text = call.kwargs.get("text", "")
        assert len(text) <= 4000

    # Verify total content is preserved (output + footer)
    total = "".join(call.kwargs.get("text", "") for call in calls[1:])
    assert total == "A" * 9000 + "\n\n—\n🔄 /iptal"


@pytest.mark.asyncio
async def test_exactly_4000_char_boundary(telegram_app, mock_update_text, test_user_id):
    """A 4000-char answer + footer must be split into 2 messages."""
    tb, app = telegram_app
    tb.executor.run = AsyncMock(return_value="B" * 4000)

    update = mock_update_text("boundary test", user_id=test_user_id)
    await app.process_update(update)

    calls = app.bot.send_message.call_args_list
    # ACK + 2 replies (main chunk + footer as separate message)
    assert len(calls) == 3
    # First chunk is exactly 4000 chars
    assert len(calls[1].kwargs.get("text", "")) == 4000
    # Last chunk is the footer
    assert "/iptal" in calls[-1].kwargs.get("text", "")


@pytest.mark.asyncio
async def test_4001_char_splits_into_two(telegram_app, mock_update_text, test_user_id):
    """A 4001-char answer must be split into 2 messages."""
    tb, app = telegram_app
    tb.executor.run = AsyncMock(return_value="C" * 4001)

    update = mock_update_text("boundary+1 test", user_id=test_user_id)
    await app.process_update(update)

    calls = app.bot.send_message.call_args_list
    # ACK + 2 replies
    assert len(calls) == 3


# ---------------------------------------------------------------------------
# Error handling UX
# ---------------------------------------------------------------------------

@pytest.mark.asyncio
async def test_error_message_is_user_friendly(telegram_app, mock_update_text, test_user_id):
    """When executor raises, the user should see a friendly error, not a traceback."""
    tb, app = telegram_app
    async def _raise(*a, **k):
        raise RuntimeError("boom")
    tb.executor.run = _raise

    update = mock_update_text("trigger error", user_id=test_user_id)
    await app.process_update(update)

    calls = app.bot.send_message.call_args_list
    final_text = calls[-1].kwargs.get("text", "")
    assert "Bir şeyler ters gitti" in final_text
    assert "/iptal" in final_text
    # Technical detail should be minimal (just exception class name)
    assert "RuntimeError" in final_text
    assert "boom" not in final_text  # raw message hidden from user


