"""Tests for Telegram message delivery: content, length, chunking, UX.

These tests mock AcpExecutor.run so they are fast and do NOT spawn
kimi-cli. They verify what the user actually sees in Telegram.
"""
from __future__ import annotations

from unittest.mock import AsyncMock

import pytest


# ---------------------------------------------------------------------------
# Message content & formatting
# ---------------------------------------------------------------------------

@pytest.mark.asyncio
async def test_short_message_delivered(telegram_app, mock_update_text, test_user_id):
    """A short answer (< 4000 chars) should be sent as a single message."""
    tb, app = telegram_app
    tb.executor.run = AsyncMock(return_value="📊 CPU: %45  |  RAM: %60")

    update = mock_update_text("sistem yükü", user_id=test_user_id)
    await app.process_update(update)

    calls = app.bot.send_message.call_args_list
    # First call = ACK, last call = final answer
    assert len(calls) >= 2
    final_text = calls[-1].kwargs.get("text", "")
    assert "CPU: %45" in final_text



