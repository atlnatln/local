# ============================================================================
# VPS Infrastructure Environment Variables
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun:
#   cp .env.example .env
# ============================================================================

# Server Information
SERVER_IP=
HOSTNAME=vps-production

# SSL Configuration
CERTBOT_EMAIL=admin@example.com

# Monitoring
ENABLE_MONITORING=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Logging
LOG_LEVEL=info
LOG_MAX_SIZE=100m
LOG_MAX_FILES=5
