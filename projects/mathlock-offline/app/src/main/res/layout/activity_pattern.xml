<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔓"
        android:textSize="48sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvPatternTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pattern_draw"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/on_surface"
        android:layout_marginBottom="24dp"
        android:gravity="center" />

    <!-- 3x3 Desen Grid -->
    <GridLayout
        android:id="@+id/patternGrid"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:columnCount="3"
        android:rowCount="3"
        android:layout_marginBottom="24dp">

        <!-- 9 dot butonu programatik olarak eklenecek -->
    </GridLayout>

    <TextView
        android:id="@+id/tvPatternSequence"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="@color/hint_blue"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPatternClear"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Temizle"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="12dp"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPatternConfirm"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/btn_ok"
            app:cornerRadius="12dp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvPatternStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp" />

</LinearLayout>
