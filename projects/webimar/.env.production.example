# ========================================
# Webimar Production Environment Variables (EXAMPLE)
# ========================================
#
# Bu dosya bir ŞABLON'dur. Gerçek secret değerleri repoya koymayın.
# Kullanım:
#   cp .env.production.example .env.production
#   # sonra kendi secret'larınızı girin

# Django Settings
DEBUG=False
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,tarimimar.com.tr,webimar-api,webimar-nginx

# Database (Production: PostgreSQL)
DATABASE_URL=postgresql://webimar:webimar123@postgres:5432/webimar

# PostgreSQL (only if using with-postgres profile)
POSTGRES_DB=webimar
POSTGRES_USER=webimar
POSTGRES_PASSWORD=webimar123

# API URLs for frontends
REACT_APP_API_BASE_URL=https://tarimimar.com.tr/api
NEXT_PUBLIC_API_BASE_URL=https://tarimimar.com.tr/api
NEXT_PUBLIC_REACT_SPA_URL=https://tarimimar.com.tr/hesaplama

# Google OAuth (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://tarimimar.com.tr/api/accounts/google/callback/

# Frontend base URL for OAuth redirects
FRONTEND_BASE_URL=https://tarimimar.com.tr

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=info@tarimimar.com.tr

# Telegram Bot Configuration (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CORS
CORS_ALLOWED_ORIGINS=https://tarimimar.com.tr,http://localhost
