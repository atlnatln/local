# ============================================================================
# Environment Variables Template - Webimar Project
# Copy this file to .env.production and fill in your values
# ============================================================================

# Django Core Settings
SECRET_KEY=your-secret-key-here-generate-with-python-manage-py-shell-minimum-50-characters
DEBUG=False

# Database Configuration
POSTGRES_DB=webimar
POSTGRES_USER=webimar
POSTGRES_PASSWORD=your-strong-password-here-minimum-12-characters
DATABASE_URL=postgresql://webimar:your-strong-password-here@postgres:5432/webimar

# Domain and URLs
ALLOWED_HOSTS=localhost,127.0.0.1,tarimimar.com.tr,webimar-api,webimar-nginx
FRONTEND_BASE_URL=https://tarimimar.com.tr

# API URLs for Frontend
REACT_APP_API_BASE_URL=https://tarimimar.com.tr/api
NEXT_PUBLIC_API_BASE_URL=https://tarimimar.com.tr/api
NEXT_PUBLIC_REACT_SPA_URL=https://tarimimar.com.tr/hesaplama

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://tarimimar.com.tr,http://localhost

# Email Configuration (Optional - for notifications)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=info@tarimimar.com.tr

# Google OAuth (Optional - for social login)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id-here
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_OAUTH_REDIRECT_URI=https://tarimimar.com.tr/api/accounts/google/callback/

# Telegram Bot (Optional - for notifications)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# SSL Certificate Email (for Let's Encrypt)
CERTBOT_EMAIL=admin@tarimimar.com.tr