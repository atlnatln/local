# Telegram Bot Token (BotFather'dan alınır)
TELEGRAM_TOKEN=your_bot_token_here

# Yetkili kullanıcı(lar) — sadece virgülle ayrılmış Telegram user ID'leri
AUTHORIZED_USERS=123456789

# Çalışma dizini (kimi-cli bu dizinde çalışacak)
WORK_DIR=/home/akn/local

# Kimi CLI komutu ve argümanları
KIMI_CMD=kimi
KIMI_ARGS=acp

# Log seviyesi (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Telegram mesaj uzunluk limiti (varsayılan 4096)
MAX_MESSAGE_LENGTH=4096

# Prompt yanıt bekleme süresi (saniye, 0 = sınırsız)
# PROMPT_TIMEOUT=0
