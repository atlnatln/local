# MathLock Play — Environment Variables
# Kopyala: cp .env.example .env && nano .env

# Django (zorunlu — fallback yok, eksikse uygulama başlamaz)
DJANGO_SECRET_KEY=change-me-to-a-50+char-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,mathlock.com.tr

# PostgreSQL
DB_NAME=mathlock
DB_USER=mathlock
DB_PASSWORD=change-me-strong-password
DB_HOST=localhost
DB_PORT=5432

# Google Play (in-app purchase doğrulama)
# JSON dosyasının tam yolunu veya JSON içeriğini string olarak verin
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=/home/akn/secrets/mathlock-play/google-service-account.json

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
