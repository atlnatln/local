    <!-- Data Usage Disclosure -->
    <string name="disclosure_title">Data Usage Disclosure</string>
    <string name="disclosure_subtitle">MathLock needs the following permissions to provide parental control. Please read before continuing.</string>

    <string name="disclosure_apps_title">📱 Installed App List</string>
    <string name="disclosure_apps_desc">Lists apps on the device so the parent can choose which to lock. This info is processed only on the device, never sent to any server, and not used for ads.</string>

    <string name="disclosure_usage_title">📊 App Usage Status</string>
    <string name="disclosure_usage_desc">Foreground app info is read to detect when a locked app is opened. This data is used only for the lock mechanism and is not recorded.</string>

    <string name="disclosure_overlay_title">🪟 Screen Overlay</string>
    <string name="disclosure_overlay_desc">Screen overlay permission is used to display the challenge screen and countdown when a locked app is opened.</string>

    <string name="disclosure_stats_title">📈 Math Performance</string>
    <string name="disclosure_stats_desc">Statistics such as correct/wrong ratio and solving time are sent securely over HTTPS. This data is used only to improve question quality. Child name, location, or personal info is not collected.</string>

    <string name="disclosure_security_note">🔒 All data transfer is done over encrypted connection (HTTPS).\nApp list and usage data are never sent to the server.</string>

    <string name="disclosure_privacy_link">Read Privacy Policy</string>
    <string name="disclosure_accept">Accept and Continue</string>
