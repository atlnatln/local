<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="6dp">

    <!-- Ön Yüz (Kapalı Kart) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardFront"
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/memory_card_back">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="?"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Arka Yüz (Açık Kart) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardBack"
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/memory_card_front"
        android:visibility="invisible">

        <TextView
            android:id="@+id/tvCardValue"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="1"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:gravity="center" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Eşleşmiş overlay (yeşil tint) -->
    <View
        android:id="@+id/matchedOverlay"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/memory_card_matched_bg"
        android:visibility="invisible" />

</FrameLayout>
