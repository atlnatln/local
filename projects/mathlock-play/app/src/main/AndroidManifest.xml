<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Ön plandaki uygulamayı tespit etmek için -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Ön plan servisi için -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Cihaz açılışında servisi başlatmak için -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Diğer uygulamaların üzerine çizim yapabilmek için -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Yüklü uygulamaları listelemek için (parental control çekirdek işlevi) -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Batarya optimizasyonundan muafiyet isteme -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Parmak izi donanım özelliği (isteğe bağlı) -->
    <uses-feature
        android:name="android.hardware.fingerprint"
        android:required="false" />

    <!-- HTTPS veri aktarımı için -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Google Play uygulama içi satın alma -->
    <uses-permission android:name="com.android.vending.BILLING" />

    <!-- Tam ekran bildirim (Android 14+: kilitli uygulama alarmı için) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MathLock"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Parental control / child monitoring beyanı -->
        <meta-data
            android:name="com.google.android.apps.MONITORING_TOOL"
            android:value="child_monitoring" />

        <!-- Ana Ekran -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Matematik Soru Ekranı -->
        <activity
            android:name=".MathChallengeActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:finishOnTaskLaunch="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.MathLock" />

        <!-- Sayı Tahmin Oyunu -->
        <activity
            android:name=".NumberGuessActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:finishOnTaskLaunch="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.MathLock" />

        <!-- Ebeveyn Kimlik Doğrulama -->
        <activity
            android:name=".ParentAuthActivity"
            android:exported="false"
            android:theme="@style/Theme.MathLock" />

        <!-- Ayarlar -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.MathLock" />

        <!-- Hesabım -->
        <activity
            android:name=".AccountActivity"
            android:exported="false"
            android:theme="@style/Theme.MathLock" />

        <!-- Çocuk Profilleri -->
        <activity
            android:name=".ChildProfilesActivity"
            android:exported="false"
            android:theme="@style/Theme.MathLock" />

        <!-- Performans Raporu -->
        <activity
            android:name=".PerformanceReportActivity"
            android:exported="false"
            android:theme="@style/Theme.MathLock" />

        <!-- İstatistik Dashboard -->
        <activity
            android:name=".StatsDashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.MathLock" />

        <!-- Uygulama Seçimi -->
        <activity
            android:name=".AppSelectionActivity"
            android:exported="false"
            android:theme="@style/Theme.MathLock" />

        <!-- Oyun Türü Seçim -->
        <activity
            android:name=".ChallengePickerActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:finishOnTaskLaunch="true"
            android:screenOrientation="portrait"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.MathLock" />

        <!-- Sayı Yolculuğu (Bulmaca Oyunu) -->
        <activity
            android:name=".SayiYolculuguActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:finishOnTaskLaunch="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MathLock" />

        <!-- Sayı Hafızası Oyunu -->
        <activity
            android:name=".MemoryGameActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:finishOnTaskLaunch="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MathLock" />

        <!-- Desen Kilidi -->
        <activity
            android:name=".PatternActivity"
            android:exported="false"
            android:theme="@style/Theme.MathLock" />

        <!-- Veri Kullanım Bildirimi (Prominent Disclosure) -->
        <activity
            android:name=".DisclosureActivity"
            android:exported="false"
            android:theme="@style/Theme.MathLock" />

        <!-- Ön Plan Servisi -->
        <service
            android:name=".service.AppLockService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <!-- Android 14: specialUse tipi için kullanım amacı bildirimi zorunlu -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Uygulama kilidi: ön plandaki uygulamayı izler ve seçili uygulamalar için matematik sorusu ekranı gösterir" />
        </service>

        <!-- Cihaz Açılışında Servisi Başlat -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
