# --- Secrets / sensitive ---
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# SSL certificates / private keys (DO NOT COMMIT)
**/ssl/**
**/*.pem
**/*.key

# Backups / deploy artifacts
**/backups/**
**/.deploy-tmp/**
**/*deploy*.tar.gz
**/deploy-*.log
**/deploy-staging/
**/deploy-artifacts/

# Logs
**/*.log

# Node / Next / React build outputs
**/node_modules/**
**/.next/**
**/out/**
**/build/**
**/dist/**

# Python caches
**/__pycache__/**
**/*.pyc
**/.pytest_cache/**

# Test / tooling outputs
**/test-results/**
**/.playwright-mcp/**

# Virtual environments created by tests or CI (do not commit)
**/test_env/**
**/*/test_env/**

# Python virtualenvs
**/venv/**
**/.venv/**
**/.venv-*/

# Kimi CLI (machine-specific sessions, logs, telemetry)
/.kimi/*
!/.kimi/skills
!/.kimi/skills/local-wiki
!/.kimi/skills/local-wiki/**

# Nested repositories (own GitHub remotes)
/ops-bot/
/projects/webimar/

# OS / IDE
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Local environment overrides
.env.local
.env.vps

# Android build outputs
**/*.apk
**/*.aab
**/*.apks
**/build/outputs/
**/build/intermediates/

# Docker image exports
**/*.tar
**/docker-images/

# Gradle cache
**/.gradle/

# Wiki machine-specific marker
wiki/.pending
